# AN API key (for token exchange from Next.js routes)
AN_API_KEY=your_an_api_key_here
# Browser Use Cloud API key from https://cloud.browser-use.com/settings?tab=api-keys
BROWSER_USE_API_KEY=your_browser_use_api_key_here
# Optional override (default: https://api.browser-use.com/api/v2)
BROWSER_USE_BASE_URL=https://api.browser-use.com/api/v2
